  "paths": {
    "/api/Client/create": {
      "post": {
        "tags": [ "Client" ],
        "summary": "Создание нового клиента",
        "operationId": "ClientCreate",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateClientRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateClientRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешное создание клиента",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "description": "ID созданного клиента"
                }
              }
            }
          },
          "400": {
            "description": "Неверный запрос"
          },
          "500": {
            "description": "Внутренняя ошибка сервера"
          }
        }
      }
    },
    "/api/Client/update": {
      "put": {
        "tags": [ "Client" ],
        "summary": "Обновление данных клиента",
        "operationId": "ClientUpdate",
