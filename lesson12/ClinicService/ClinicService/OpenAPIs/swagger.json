  "components": {
    "schemas": {
      "CreateClientRequest": {
        "type": "object",
        "properties": {
          "document": {
            "type": "string",
            "description": "Паспортные данные"
          },
          "surName": {
            "type": "string",
            "description": "Фамилия"
          },
          "firstName": {
            "type": "string",
            "description": "Имя"
          },
          "patronymic": {
            "type": "string",
            "nullable": true,
            "description": "Отчество"
          },
          "birthday": {
            "type": "string",
            "format": "date-time",
            "description": "Дата рождения"
          }
        },
        "required": [ "document", "surName", "firstName", "birthday" ]
      },
      "UpdateClientRequest": {
        "type": "object",
        "properties": {
          "clientId": {
            "type": "integer",
            "format": "int32",
            "description": "ID клиента"
          },
          "document": {
            "type": "string"
          },
          "surName": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "patronymic": {
            "type": "string",
            "nullable": true
          },
          "birthday": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [ "clientId", "document", "surName", "firstName", "birthday" ]
      },
      "ClientResponse": {
        "type": "object",
        "properties": {
          "clientId": {
            "type": "integer",
            "format": "int32"
          },
          "document": {
            "type": "string"
          },
          "surName": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "patronymic": {
            "type": "string",
            "nullable": true
          },
          "birthday": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreatePetRequest": {
        "type": "object",
        "properties": {
          "clientId": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string"
          },
          "birthday": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [ "clientId", "name", "birthday" ]
      },
      "UpdatePetRequest": {
        "type": "object",
        "properties": {
          "petId": {
            "type": "integer",
            "format": "int32"
          },
          "clientId": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string"
          },
          "birthday": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [ "petId", "clientId", "name", "birthday" ]
      },
      "PetResponse": {
        "type": "object",
        "properties": {
          "petId": {
            "type": "integer",
            "format": "int32"
          },
          "clientId": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string"
          },
          "birthday": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateConsultationRequest": {
        "type": "object",
        "properties": {
          "clientId": {
            "type": "integer",
            "format": "int32"
          },
          "petId": {
            "type": "integer",
            "format": "int32"
          },
          "consultationDate": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [ "clientId", "petId", "consultationDate", "description" ]
      },
      "UpdateConsultationRequest": {
        "type": "object",
        "properties": {
          "consultationId": {
            "type": "integer",
            "format": "int32"
          },
          "clientId": {
            "type": "integer",
            "format": "int32"
          },
          "petId": {
            "type": "integer",
            "format": "int32"
          },
          "consultationDate": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [ "consultationId", "clientId", "petId", "consultationDate", "description" ]
      },
      "ConsultationResponse": {
        "type": "object",
        "properties": {
