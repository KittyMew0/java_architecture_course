              "application/json": {
                "schema": {
                  "type": "integer",
                  "description": "Количество затронутых записей"
                }
              }
            }
          },
          "404": {
            "description": "Клиент не найден"
          }
        }
      }
    },
    "/api/Client/delete": {
      "delete": {
        "tags": [ "Client" ],
        "summary": "Удаление клиента",
        "operationId": "ClientDelete",
        "parameters": [
          {
            "name": "clientId",
            "in": "query",
            "required": true,
